# AI postmortems use OpenRouter. Get a key at https://openrouter.ai/
# Without this set, the rest of the app works; the Generate Postmortem button returns a clear error.
OPENROUTER_API_KEY=

# Optional: only consulted when starting with --smtp / -Smtp. Without that flag,
# alerts are captured to the database and shown in the in-app Sent Notifications panel.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_STARTTLS=true
